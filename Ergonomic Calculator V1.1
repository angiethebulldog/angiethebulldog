<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Personalized Ergonomic Calculator</title>
  <meta name="description" content="Ergonomic calculator with live unit conversion and mobile-friendly layout." />
  <style>
    :root {
      --bg: #f5f7fb;
      --card-bg: #ffffff;
      --text: #333333;
      --muted: #666666;
      --border: #eeeeee;
      --accent: #3498db;
      --accent-dark: #2980b9;
      --shadow: 0 10px 30px rgba(0,0,0,0.1);
      --radius-lg: 20px;
      --radius-md: 12px;
    }

    html, body { height: 100%; }
    body {
      background: var(--bg);
      margin: 0;
      padding: 20px;
      font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
      color: var(--text);
    }

    .container {
      max-width: 680px;
      margin: 10px auto;
      padding: 20px;
      border: 2px solid var(--border);
      border-radius: var(--radius-lg);
      background-color: var(--card-bg);
      box-shadow: var(--shadow);
    }

    h1, h2, h3 { margin: 0 0 12px; }
    h2 { text-align: center; color: #1a1a1b; margin-bottom: 18px; }

    .unit-toggle {
      display: flex; justify-content: center; gap: 30px; font-weight: bold; margin-bottom: 18px;
    }
    .unit-toggle label { cursor: pointer; }

    .grid-2 {
      display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;
    }

    label { display: block; font-size: 0.9em; margin-bottom: 6px; font-weight: 600; }
    .unit-tag { color: var(--muted); font-weight: 600; margin-left: 6px; }

    input[type="number"], select {
      width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; background: #fff; color: var(--text);
    }

    .hint { color: var(--muted); font-size: 0.8em; margin-top: 6px; display: inline-block; }

    .btn {
      width: 100%; padding: 16px; background-color: #000; color: #fff; border: none; border-radius: 8px; font-size: 1.05em; font-weight: bold; cursor: pointer;
    }
    .btn:focus { outline: 3px solid var(--accent); outline-offset: 2px; }

    .results {
      margin-top: 24px; display: none; padding: 20px; background: #fdfdfd; border: 1px solid var(--border); border-radius: var(--radius-md); border-top: 5px solid var(--accent);
    }
    .results h3 { margin-top: 0; color: var(--accent-dark); }

    .notice { font-size: 0.85em; color: #4a4a4a; background: #f0f7ff; border: 1px solid #e0efff; padding: 10px 12px; border-radius: 10px; margin-bottom: 16px; }

    /* Remove spinners on number fields */
    input[type="number"]::-webkit-outer-spin-button,
    input[type="number"]::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
    input[type="number"] { -moz-appearance: textfield; }

    /* Mobile responsiveness */
    @media (max-width: 640px) {
      body { padding: 12px; }
      .container { padding: 16px; }
      .grid-2 { grid-template-columns: 1fr; gap: 14px; }
      .unit-toggle { gap: 18px; }
      .btn { padding: 14px; font-size: 1em; }
    }
  </style>
</head>
<body>
  <div class="container" id="ergo-calculator-container">
    <h2>Personalized Ergonomic Calculator</h2>

    <div class="notice">Enter your measurements and switch units any time — values will convert automatically between centimeters and inches.</div>

    <div class="unit-toggle" role="radiogroup" aria-label="Select measurement unit">
      <label><input type="radio" name="unit" value="cm" checked aria-label="Centimeters"> Centimeters (cm)</label>
      <label><input type="radio" name="unit" value="in" aria-label="Inches"> Inches (in)</label>
    </div>

    <div class="grid-2">
      <div>
        <label for="userHeight">Your Height <span class="unit-tag" id="u-height">cm</span></label>
        <input type="number" id="userHeight" placeholder="e.g. 175" min="0" step="0.1">
        <span class="hint">Measure from floor to top of head (without shoes).</span>
      </div>

      <div>
        <label for="currDesk">Current Desk Height <span class="unit-tag" id="u-desk">cm</span></label>
        <input type="number" id="currDesk" placeholder="e.g. 75" min="0" step="0.1">
      </div>

      <div>
        <label for="currChair">Current Chair Height <span class="unit-tag" id="u-chair">cm</span></label>
        <input type="number" id="currChair" placeholder="e.g. 52" min="0" step="0.1">
      </div>

      <div>
        <label for="currDepth">Current Seat Depth <span class="unit-tag" id="u-depth">cm</span></label>
        <input type="number" id="currDepth" placeholder="e.g. 45" min="0" step="0.1">
      </div>
    </div>

    <div style="margin-bottom: 18px;">
      <label for="kbPlacement">Keyboard Placement</label>
      <select id="kbPlacement">
        <option value="on-desk">Placed on Desk Surface</option>
        <option value="tray">Placed on Under-desk Tray</option>
      </select>
    </div>

    <button class="btn" id="calcBtn" type="button">Calculate Best Setup</button>

    <div class="results" id="ergoResults" aria-live="polite">
      <h3>Optimal Settings:</h3>
      <div id="resultsContent" style="line-height: 1.7;"></div>
    </div>
  </div>

  <script>
    (function() {
      const CM_PER_IN = 2.54;
      const els = {
        height: document.getElementById('userHeight'),
        desk: document.getElementById('currDesk'),
        chair: document.getElementById('currChair'),
        depth: document.getElementById('currDepth'),
        kbPlacement: document.getElementById('kbPlacement'),
        results: document.getElementById('ergoResults'),
        content: document.getElementById('resultsContent'),
        calcBtn: document.getElementById('calcBtn'),
        unitRadios: document.querySelectorAll('input[name="unit"]'),
        unitTags: {
          height: document.getElementById('u-height'),
          desk: document.getElementById('u-desk'),
          chair: document.getElementById('u-chair'),
          depth: document.getElementById('u-depth'),
        }
      };

      function getUnit() {
        const r = document.querySelector('input[name="unit"]:checked');
        return r ? r.value : 'cm';
      }

      function isNumeric(n) {
        return typeof n === 'number' && !Number.isNaN(n) && Number.isFinite(n);
      }

      function roundTo(val, decimals) {
        const p = Math.pow(10, decimals);
        return Math.round((val + Number.EPSILON) * p) / p;
      }

      function convert(val, fromUnit, toUnit) {
        if (!isNumeric(val)) return '';
        if (fromUnit === toUnit) return val;
        if (fromUnit === 'cm' && toUnit === 'in') return val / CM_PER_IN;
        if (fromUnit === 'in' && toUnit === 'cm') return val * CM_PER_IN;
        return val;
      }

      function convertField(inputEl, fromUnit, toUnit) {
        const v = parseFloat(inputEl.value);
        if (!isNumeric(v)) return; // skip empty or invalid
        const converted = convert(v, fromUnit, toUnit);
        inputEl.value = isNumeric(converted) ? roundTo(converted, 1) : '';
      }

      function updateUnitTags(unit) {
        els.unitTags.height.textContent = unit;
        els.unitTags.desk.textContent = unit;
        els.unitTags.chair.textContent = unit;
        els.unitTags.depth.textContent = unit;
        // Optionally tweak placeholders to a unit-appropriate example
        const ph = (id, cmVal) => {
          if (unit === 'cm') return String(cmVal);
          // convert example to inches and round to 1
          const inches = roundTo(cmVal / CM_PER_IN, 1);
          return String(inches);
        };
        els.height.placeholder = 'e.g. ' + ph('userHeight', 175);
        els.desk.placeholder   = 'e.g. ' + ph('currDesk', 75);
        els.chair.placeholder  = 'e.g. ' + ph('currChair', 52);
        els.depth.placeholder  = 'e.g. ' + ph('currDepth', 45);
      }

      function handleUnitToggle() {
        // Determine previous and next units
        const prevUnit = (handleUnitToggle.currentUnit || 'cm');
        const nextUnit = getUnit();
        if (prevUnit === nextUnit) return;

        // Convert existing numeric values in fields
        [els.height, els.desk, els.chair, els.depth].forEach(el => convertField(el, prevUnit, nextUnit));

        // Update UI unit tags & placeholders
        updateUnitTags(nextUnit);

        // Recalculate results (if visible)
        if (els.results.style.display === 'block') {
          calculateErgo();
        }

        handleUnitToggle.currentUnit = nextUnit;
      }
      handleUnitToggle.currentUnit = getUnit();

      function calculateErgo() {
        // Clear previous output
        els.content.innerHTML = '';

        try {
          const height = parseFloat(els.height.value);
          const currDesk = parseFloat(els.desk.value);
          const currChair = parseFloat(els.chair.value);
          const kbType = els.kbPlacement.value;
          const unit = getUnit();

          // Validation - required fields
          if (!height || !currDesk || !currChair) {
            alert('Please fill in your height, desk height, and chair height.');
            return;
          }

          // Calculation Ratios (Calibrated to 52-54cm for 175-180cm height)
          const idealSeat = (height * 0.30);
          const idealDesk = (height * 0.42);
          const idealDepth = (height * 0.23);

          let recommendations = '';

          // Keyboard Tray Logic
          const threshold = (unit === 'cm') ? 3 : 1.2;
          if (kbType === 'on-desk' && currDesk > (idealDesk + threshold)) {
            recommendations += '<li><strong>Keyboard Tray:</strong> ⚠️ <strong>Highly Recommended.</strong> Your desk surface is too high for ergonomic typing. A tray would lower your wrists to the ideal</li>';
          }

          // Foot Rest Logic
          if (currChair > (idealSeat + (unit === 'cm' ? 2 : 0.8))) {
            recommendations += '<li><strong>Foot Rest:</strong> ⚠️ <strong>Required.</strong> Your chair is too high for your legs; use a rest to maintain support.</li>';
          }

          els.content.innerHTML = `
            <ul style="padding-left: 20px; list-style-type: square;">
              <li><strong>Best Seat Height:</strong> ${roundTo(idealSeat, 1)}${unit}</li>
              <li><strong>Best Seat Depth:</strong> ${roundTo(idealDepth, 1)}${unit}</li>
              <li><strong>Best Keyboard Height:</strong> ${roundTo(idealDesk, 1)}${unit}</li>
              <hr style="border: 0; border-top: 1px solid #eee; margin: 15px 0;">
              ${recommendations || '<li><em>Your current physical setup is well-aligned.</em></li>'}
            </ul>
          `;

          els.results.style.display = 'block';
        } catch (e) {
          console.error(e);
          alert('An error occurred. Please check your inputs.');
        }
      }

      // Event listeners
      els.calcBtn.addEventListener('click', calculateErgo);
      els.unitRadios.forEach(r => r.addEventListener('change', handleUnitToggle));

      // Initialize placeholders/suffixes to selected unit on load
      updateUnitTags(getUnit());
    })();
  </script>
</body>
</html>
